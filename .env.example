# ============================================================================
# AquaSignal — environment variables, one block per place they get set.
# Copy values into the right dashboard; NEVER commit a real .env (gitignored).
# ============================================================================

# ----------------------------------------------------------------------------
# RENDER (dashboard → aquasignal-api → Environment)  — the API
# ----------------------------------------------------------------------------
# Supabase "Session pooler" connection string (IPv4!). Plain postgresql:// is
# fine — the backend adds the +asyncpg driver itself.
# Get it: Supabase → Connect → Session pooler.
AQUASIGNAL_DATABASE_URL=postgresql://postgres.YOURREF:YOURPASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# JSON list of allowed browser origins — your Vercel URL.
AQUASIGNAL_CORS_ORIGINS=["https://aquasignal.vercel.app"]

# Random secrets. render.yaml asks Render to generate both automatically;
# copy AQUASIGNAL_INTERNAL_API_TOKEN into the GitHub secret of the same name.
AQUASIGNAL_JWT_SECRET_KEY=generate-a-random-32+-char-string
AQUASIGNAL_INTERNAL_API_TOKEN=generate-a-different-random-string

# OPTIONAL — AI water-planning advisor (OpenRouter). Leave the key empty to
# disable the advisor entirely (the UI hides the section). Get a key at
# https://openrouter.ai/keys. The model id is overridable; the default below is
# what the feature ships with.
AQUASIGNAL_OPENROUTER_API_KEY=
AQUASIGNAL_OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# OPTIONAL — push alerts. Base64 of the Firebase service-account JSON file:
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("firebase.json"))
#   macOS/Linux: base64 -w0 firebase.json
# Omit entirely to run without push notifications.
FIREBASE_CREDENTIALS_JSON=

# OPTIONAL — Hugging Face hosted models. Leave unset to use the model files
# bundled in the repo (downscaler.pkl + forecaster.pt, ~4.3 MB total).
HF_REPO_ID=
HF_TOKEN=
# When HF_REPO_ID is set, also point the API at the downloaded copies:
# AQUASIGNAL_DOWNSCALER_PATH=/tmp/models/downscaler.pkl
# AQUASIGNAL_FORECASTER_PATH=/tmp/models/forecaster.pt

# ----------------------------------------------------------------------------
# GITHUB → repo → Settings → Secrets and variables → Actions → "Secrets"
# (used by cron.yml, bootstrap.yml, keepalive.yml)
# ----------------------------------------------------------------------------
# Same Supabase session-pooler string as above (plain postgresql:// scheme).
DATABASE_URL=postgresql://postgres.YOURREF:YOURPASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# NASA Earthdata login (free): https://urs.earthdata.nasa.gov  — GRACE-FO data.
EARTHDATA_USER=
EARTHDATA_PASS=

# Google Earth Engine service account (free for noncommercial use):
# https://console.cloud.google.com → IAM → Service Accounts → create key (JSON).
# EE_SERVICE_ACCOUNT is the account email; GEE_PRIVATE_KEY_JSON is the FULL
# JSON key file content pasted as one secret; GEE_PROJECT the GCP project id.
EE_SERVICE_ACCOUNT=aquasignal@your-project.iam.gserviceaccount.com
GEE_PRIVATE_KEY_JSON=
GEE_PROJECT=your-project-id

# Must equal Render's AQUASIGNAL_INTERNAL_API_TOKEN (cron → POST /alerts/trigger).
AQUASIGNAL_INTERNAL_API_TOKEN=

# OPTIONAL — Discord channel webhook for pipeline-failure alerts:
# channel → Edit → Integrations → Webhooks → New Webhook → Copy URL.
DISCORD_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# GITHUB → same page → "Variables" tab (not secret — it's a public URL)
# ----------------------------------------------------------------------------
RENDER_URL=https://aquasignal-api.onrender.com

# ----------------------------------------------------------------------------
# VERCEL (dashboard → project → Settings → Environment Variables) — frontend
# ----------------------------------------------------------------------------
VITE_API_URL=https://aquasignal-api.onrender.com
