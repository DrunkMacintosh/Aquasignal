# Copy to .env.local (gitignored) and adjust if needed. With the defaults
# below the dashboard runs with NO credentials at all.
# Vite only exposes variables prefixed VITE_ to the browser bundle.

# FastAPI backend (backend/app.py). 127.0.0.1 avoids Windows localhost/IPv6 quirks.
VITE_API_URL=http://127.0.0.1:8000

# The basemap is the keyless Esri World Imagery satellite layer (plus Esri's
# reference labels) — defined in src/components/Map.jsx, no token needed.
