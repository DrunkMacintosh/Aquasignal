# Used by `vite build` in production. The Vercel dashboard environment
# variable VITE_API_URL (Settings → Environment Variables) takes precedence
# over this file — set it there to your real Render URL. This placeholder
# exists so a local production build fails loudly against the wrong API
# rather than silently hitting localhost.
VITE_API_URL=https://aquasignal-api.onrender.com
