# Copy to .env and fill in real values. Never commit .env.
AQUASIGNAL_DATABASE_URL=postgresql+asyncpg://aquasignal:CHANGE_ME@localhost:5432/aquasignal

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AQUASIGNAL_JWT_SECRET_KEY=CHANGE_ME

# Shared secret between monthly_cron.py and POST /alerts/trigger
AQUASIGNAL_INTERNAL_API_TOKEN=CHANGE_ME

# Firebase service-account JSON for Cloud Messaging
AQUASIGNAL_FIREBASE_CREDENTIALS_FILE=secrets/firebase-service-account.json

# Comma-separated origins allowed by CORS (JSON list)
AQUASIGNAL_CORS_ORIGINS=["http://localhost:3000"]
